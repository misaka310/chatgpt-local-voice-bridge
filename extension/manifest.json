{
  "manifest_version": 3,
  "name": "ChatGPT Local Voice Bridge",
  "version": "0.1.0",
  "description": "Reads ChatGPT web responses through a local Irodori direct TTS API.",
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1:8717/*",
    "http://localhost:8717/*"
  ],
  "background": {
    "service_worker": "background-entry.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_title": "ChatGPT Local Voice Bridge",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  }
}
