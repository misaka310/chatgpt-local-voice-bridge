{
  "manifest_version": 3,
  "name": "ChatGPT Local Voice Bridge",
  "version": "0.1.0",
  "description": "Reads ChatGPT web responses through a local TTS API such as Qwen3-TTS/ComfyUI.",
  "permissions": ["storage", "nativeMessaging"],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "ChatGPT Local Voice Bridge"
  }
}
